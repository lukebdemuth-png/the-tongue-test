{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Holistic Medicine Research Record",
  "type": "object",
  "required": [
    "source_url",
    "title",
    "authors",
    "publication_source",
    "date",
    "tradition",
    "source_type",
    "access_status",
    "retrieval_date",
    "summary",
    "extracted_concepts",
    "symptom_clusters",
    "diagnosis_pattern",
    "intervention",
    "outcome",
    "limitations",
    "confidence_language",
    "source_scores"
  ],
  "properties": {
    "title": { "type": "string" },
    "authors": { "type": "array", "items": { "type": "string" } },
    "publication": { "type": "string" },
    "date": { "type": "string" },
    "abstract": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "symptoms": { "type": "array", "items": { "type": "string" } },
    "interventions": { "type": "array", "items": { "type": "string" } },
    "outcomes": { "type": "array", "items": { "type": "string" } },
    "confidence_language": { "type": "array", "items": { "type": "string" } },
    "tradition": { "type": "array", "items": { "type": "string" } },
    "source_url": { "type": "string" },
    "retrieval_date": { "type": "string" },
    "source_name": { "type": "string" },
    "source_type": { "type": "string" },
    "identifiers": { "type": "object" },
    "open_access": { "type": ["boolean", "null"] },
    "license": { "type": "string" },
    "full_text_url": { "type": "string" },
    "pdf_url": { "type": "string" },
    "text": { "type": "string" }
    ,
    "publication_source": { "type": "string" },
    "access_status": { "type": "string" },
    "summary": { "type": "string" },
    "extracted_concepts": { "type": "array", "items": { "type": "string" } },
    "symptom_clusters": { "type": "array", "items": { "type": "string" } },
    "intervention": { "type": "array", "items": { "type": "string" } },
    "outcome": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "source_scores": {
      "$ref": "source_scoring_schema.json"
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "priority": { "type": "string" },
    "references": { "type": "array", "items": { "type": "object" } },
    "terminology": { "type": "array", "items": { "type": "string" } },
    "system_architecture_ideas": { "type": "array", "items": { "type": "string" } },
    "decision_support_logic": { "type": "array", "items": { "type": "string" } },
    "clinical_reasoning_frameworks": { "type": "array", "items": { "type": "string" } }
    ,
    "diagnosis_pattern": { "type": "array", "items": { "type": "string" } },
    "contradictions_limitations": { "type": "array", "items": { "type": "string" } },
    "source_collection": { "type": "string" },
    "remedy_relationships": { "type": "array", "items": { "type": "string" } },
    "symptom_pattern_relationships": { "type": "array", "items": { "type": "string" } },
    "intervention_sequencing": { "type": "array", "items": { "type": "string" } },
    "constitutional_descriptions": { "type": "array", "items": { "type": "string" } },
    "case_reasoning": { "type": "array", "items": { "type": "string" } },
    "differential_remedy_logic": { "type": "array", "items": { "type": "string" } }
  }
}
