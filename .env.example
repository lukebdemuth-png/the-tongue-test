# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase server-side API access.
# Keep SUPABASE_SERVICE_ROLE_KEY server-only. Never expose it in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_WAITLIST_TABLE=waitlist_subscribers

# Optional public Supabase values for future browser/client features.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Waitlist local fallback for development only.
WAITLIST_FILE_PATH=logs/waitlist_submissions.jsonl

# Optional Resend notification email.
RESEND_API_KEY=
WAITLIST_NOTIFY_EMAIL=
WAITLIST_FROM_EMAIL=waitlist@yourdomain.com
WAITLIST_CONFIRMATION_ENABLED=false

# Optional newsletter sync. Keep disabled until a provider is chosen and tested.
NEWSLETTER_PROVIDER=
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Optional analytics.
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Future embeddings/vector setup.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
