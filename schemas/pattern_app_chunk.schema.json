{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.pattern-app/schemas/pattern_app_chunk.schema.json",
  "title": "Pattern App Normalized Chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "source_id",
    "book",
    "tradition",
    "school",
    "source_category",
    "canonical_layer",
    "volume",
    "title",
    "author_authors",
    "translator_authors",
    "editor_commentator",
    "edition",
    "source_url",
    "source_access_status",
    "license_or_rights_note",
    "retrieval_date",
    "page_start",
    "page_end",
    "stable_locator",
    "section",
    "chapter",
    "sutra_or_aphorism",
    "entry_type",
    "language",
    "sanskrit_text",
    "source_language_text",
    "english_text",
    "text",
    "keywords",
    "concepts",
    "symptoms",
    "patterns",
    "interventions",
    "contraindications",
    "text_layer_type",
    "ocr_engine",
    "ocr_confidence",
    "extraction_notes"
  ],
  "properties": {
    "chunk_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "book": {"type": "string", "minLength": 1},
    "tradition": {
      "type": "string",
      "enum": ["Ayurveda", "Traditional Chinese Medicine", "Homeopathy"]
    },
    "school": {"type": "string", "minLength": 1},
    "source_category": {"type": "string", "minLength": 1},
    "canonical_layer": {"type": "string", "minLength": 1},
    "volume": {"type": "string"},
    "title": {"type": "string", "minLength": 1},
    "author_authors": {"type": "array", "items": {"type": "string"}},
    "translator_authors": {"type": "array", "items": {"type": "string"}},
    "editor_commentator": {"type": "array", "items": {"type": "string"}},
    "edition": {"type": "string"},
    "source_url": {"type": "string", "minLength": 1},
    "source_access_status": {"type": "string", "minLength": 1},
    "license_or_rights_note": {"type": "string", "minLength": 1},
    "retrieval_date": {"type": "string", "minLength": 1},
    "page_start": {"type": ["integer", "null"]},
    "page_end": {"type": ["integer", "null"]},
    "stable_locator": {"type": "string", "minLength": 1},
    "section": {"type": "string"},
    "chapter": {"type": "string"},
    "sutra_or_aphorism": {"type": "string"},
    "entry_type": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 1},
    "sanskrit_text": {"type": "string"},
    "source_language_text": {"type": "string"},
    "english_text": {"type": "string"},
    "text": {"type": "string"},
    "keywords": {"type": "array", "items": {"type": "string"}},
    "concepts": {"type": "array", "items": {"type": "string"}},
    "symptoms": {"type": "array", "items": {"type": "string"}},
    "patterns": {"type": "array", "items": {"type": "string"}},
    "interventions": {"type": "array", "items": {"type": "string"}},
    "contraindications": {"type": "array", "items": {"type": "string"}},
    "text_layer_type": {"type": "string", "minLength": 1},
    "ocr_engine": {"type": ["string", "null"]},
    "ocr_confidence": {"type": ["number", "null"]},
    "extraction_notes": {"type": "string"}
  },
  "additionalProperties": false
}
